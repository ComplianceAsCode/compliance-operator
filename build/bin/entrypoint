#!/bin/sh -e

# This is documented here:
# https://docs.redhat.com/en/documentation/openshift_container_platform/4.19/html/images/creating-images#images-create-guide-openshift_create-images

# Modern OCP 4.19+ supports arbitrary UIDs without requiring /etc/passwd entries
# The container runs with the UID assigned by the platform, with group 0 (root) membership
# File permissions are managed through group ownership, not username lookups

exec ${OPERATOR} $@
